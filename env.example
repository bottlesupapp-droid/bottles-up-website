# --- Client-side (Vite) env vars: safe to expose in the browser bundle ---

# Supabase project (Project Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# --- Checkout redirects to Stripe-hosted Checkout Sessions (no Stripe.js in the ---
# --- browser), so no publishable key is needed client-side. Everything else ---
# --- (Stripe secret key, Stripe webhook secret, Resend API key, ---
# --- Mailchimp API key, Supabase service_role key) lives ONLY as Supabase Edge ---
# --- Function secrets (supabase secrets set ...), never in this file or the ---
# --- client bundle. See supabase/functions/*/README or DEPLOYMENT.md. ---
