# Mailchimp Configuration
# Get these from your Mailchimp account dashboard

# Your Mailchimp API Key (found in Account > Extras > API keys)
MAILCHIMP_API_KEY=your_api_key_here

# Your Mailchimp server prefix (e.g., us1, us2, us3, etc.)
# Found in the URL when you're logged into Mailchimp (e.g., https://us1.admin.mailchimp.com/)
MAILCHIMP_SERVER_PREFIX=us1

# Your Mailchimp Audience/List ID (found in Audience > Settings > Audience name and defaults)
MAILCHIMP_LIST_ID=your_list_id_here

# Server Configuration
PORT=3001